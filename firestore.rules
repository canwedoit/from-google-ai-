rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function userId() {
      return request.auth.uid;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
               request.auth.token.email == 'saso4redbubble@gmail.com' || 
               request.auth.token.email == 'admin@example.com' ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
             );
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidSite(data) {
      return data.keys().hasAll(['name', 'basePrice']) &&
             data.name is map && 
             data.basePrice is number && data.basePrice >= 0 &&
             (!data.keys().hasAny(['governorateId']) || data.governorateId is string) &&
             (!data.keys().hasAny(['images']) || (data.images is list && data.images.size() <= 20));
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'siteId', 'bookingDate', 'category', 'price', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.userId == userId() &&
             data.siteId is string &&
             data.bookingDate is string &&
             data.category in ['adult', 'student', 'child'] &&
             data.price is number && data.price >= 0 &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /sites {
      allow list: if true;
      match /{siteId} {
        allow get: if true;
        allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == 'saso4redbubble@gmail.com');
      }
    }

    match /users/{uid} {
      allow get: if isSignedIn() && (uid == userId() || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && uid == userId();
      allow update: if isSignedIn() && uid == userId() && 
                    (isAdmin() || !incoming().diff(existing()).affectedKeys().hasAny(['role']));
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (existing().userId == userId() || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == userId() || isAdmin());
      allow create: if isSignedIn() && 
                    isValidId(bookingId) && 
                    isValidBooking(incoming()) &&
                    exists(/databases/$(database)/documents/sites/$(incoming().siteId));
      allow update, delete: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
